{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Tiltfile$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-zA-Z0-9-._]+) depName=(?<depName>[^\\s]+)\\s+[A-Z0-9_]+_VERSION\\s*=\\s*['\"](?<currentValue>[^'\"]+)['\"]"
      ]
    }
  ]
}
